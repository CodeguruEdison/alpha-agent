# ── AI Models ─────────────────────────────────
# Groq — https://console.groq.com (free, sign up)
GROQ_API_KEY=

# Ollama runs locally — no key needed
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── Market Data ───────────────────────────────
# Polygon.io — https://polygon.io (free delayed tier)
POLYGON_API_KEY=

# Finnhub — https://finnhub.io (free 60 req/min)
FINNHUB_API_KEY=

# Alpha Vantage — https://alphavantage.co (free 25 req/day)
ALPHA_VANTAGE_API_KEY=

# FRED — https://fred.stlouisfed.org/docs/api (free)
FRED_API_KEY=

# ── Cache ─────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── App ───────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Frontend ──────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
```

